# ECG Monitoring System - Environment
# Copy to .env and adjust.

# Database (default: SQLite in project root)
# DATABASE_URL=sqlite+aiosqlite:///./ecg_monitoring.db

# ECG processing (aligned with AD8232)
# ECG_SAMPLE_RATE=360
# ECG_BANDPASS_LOW=0.5
# ECG_BANDPASS_HIGH=40
# BRADYCARDIA_THRESHOLD=60
# TACHYCARDIA_THRESHOLD=100

# API prefix
# API_V1_PREFIX=/api/v1

# Auth (change in production)
# SECRET_KEY=change-in-production-academic-use-only
